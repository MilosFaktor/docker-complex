{
    "AWSEBDockerrunVersion": 2,
    "containerDefinitions": [
        {
        "name": "client",
        "image": "418272797873.dkr.ecr.eu-north-1.amazonaws.com/milosfaktor/complex-client:__IMAGE_TAG__",
        "essential": false,
        "memory": 128
        },
        {
        "name": "nginx",
        "image": "418272797873.dkr.ecr.eu-north-1.amazonaws.com/milosfaktor/complex-nginx:__IMAGE_TAG__",
        "essential": true,
        "memory": 128,
        "portMappings": [
            {
            "hostPort": 80,
            "containerPort": 80
            }
        ]
        },
        {
        "name": "api",
        "image": "418272797873.dkr.ecr.eu-north-1.amazonaws.com/milosfaktor/complex-server:__IMAGE_TAG__",
        "essential": false,
        "memory": 128
        },
        {
        "name": "worker",
        "image": "418272797873.dkr.ecr.eu-north-1.amazonaws.com/milosfaktor/complex-worker:__IMAGE_TAG__",
        "essential": false,
        "memory": 128
        }
    ]
    }